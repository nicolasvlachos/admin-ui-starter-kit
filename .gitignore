# ──────────────────────────────────────────────────────────────────────
# Admin UI Starter Kit — repository ignore rules
# Grouped by what's being ignored and why, so you can edit confidently.
# ──────────────────────────────────────────────────────────────────────

# ── Dependencies ──────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz

# ── Build & publish artifacts ─────────────────────────────────────────
# `dist/` is the publishable artifact — generated by `npm run build:lib`
# and re-built on every `npm publish` via `prepublishOnly`. Never commit.
dist/
dist-ssr/
build/
out/
.vite/
.vite-plugin-dts/

# Tarballs from `npm pack` — temporary by design.
*.tgz

# ── Caches ────────────────────────────────────────────────────────────
.cache/
.parcel-cache/
.turbo/
.next/
.nuxt/
.eslintcache
.stylelintcache
*.tsbuildinfo
node_modules/.tmp/

# Vitest / Jest
coverage/
.vitest/
junit.xml

# ── Logs ──────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Environment ───────────────────────────────────────────────────────
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local

# ── Editors ───────────────────────────────────────────────────────────
# VS Code: keep `extensions.json` shareable, ignore everything else.
.vscode/*
!.vscode/extensions.json

# JetBrains
.idea/

# Vim / Emacs / Sublime
*.swp
*.swo
*.sw?
*~
.\#*
\#*\#

# ── OS noise ──────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Visual Studio (Windows toolchain) ─────────────────────────────────
*.suo
*.ntvs*
*.njsproj
*.sln

# ── Local-only repo state ─────────────────────────────────────────────
# Top-level `references/` holds AI-assisted reference copies of consuming-app
# code during migration work. Never published. Scoped to the repo root so it
# doesn't shadow legitimate `references/` subfolders inside skills.
/references/

# `.claude/` — local Claude Code state (worktrees, settings, scheduled
# tasks, transient skill copies). Skills authored as part of the repo
# live in `.agents/skills/` and ARE checked in. The mandatory skill
# (`component-library-rules`) is symlinked from `.claude/skills/` into
# `.agents/skills/` for local convenience; the symlinks themselves are
# not tracked.
.claude/

# Lockfile for slash-command / skill state. Local-only.
skills-lock.json

# Misc local-only files
*.local
