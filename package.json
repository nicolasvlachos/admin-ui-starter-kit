{
  "name": "admin-ui-starter-kit",
  "version": "0.1.0",
  "description": "Opinionated React component kit for admin panels and SaaS dashboards, built on top of shadcn/ui + Tailwind CSS v4. Callback-driven, framework-agnostic, i18n-ready.",
  "type": "module",
  "license": "MIT",
  "author": "Nicolas Vlachos",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nicolasvlachos/admin-ui-starter-kit.git"
  },
  "homepage": "https://github.com/nicolasvlachos/admin-ui-starter-kit#readme",
  "bugs": {
    "url": "https://github.com/nicolasvlachos/admin-ui-starter-kit/issues"
  },
  "keywords": [
    "react",
    "component-library",
    "shadcn",
    "tailwind",
    "ui",
    "framework-agnostic",
    "design-system",
    "admin",
    "admin-panel",
    "dashboard",
    "starter-kit"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CLAUDE.md",
    "AGENTS.md",
    ".agents/skills/component-library-rules",
    "scripts/install-skill.mjs",
    "scripts/serve-showcase.mjs"
  ],
  "bin": {
    "admin-ui-starter-kit-install-skill": "./scripts/install-skill.mjs",
    "admin-ui-starter-kit-showcase": "./scripts/serve-showcase.mjs"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:showcase": "vite build --outDir dist/showcase --emptyOutDir --base=./",
    "build:lib": "node scripts/clean-dist.mjs && vite build -c vite.lib.config.ts && tailwindcss -i ./src/App.css -o ./dist/style.css --minify",
    "lint": "eslint .",
    "lint:architecture": "node scripts/check-architecture.mjs",
    "test:exports": "node scripts/check-package-exports.mjs",
    "docs:generate-props": "node scripts/generate-props-tables.mjs",
    "docs:check-props": "node scripts/check-props-fresh.mjs",
    "docs:sync-skill": "node scripts/sync-skill-components.mjs",
    "typecheck": "tsc -p tsconfig.app.json --noEmit --ignoreDeprecations 6.0",
    "verify": "npm run lint:architecture && npm run test:exports && npm run docs:check-props && npm run docs:sync-skill -- --check && npm run typecheck && npm run lint && npm run test -- --pool=threads --maxWorkers=1",
    "test": "vitest run",
    "preview": "vite preview",
    "prepublishOnly": "npm run build:lib && npm run build:showcase",
    "publish:skill": "node scripts/publish-skill.mjs"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./style.css": "./dist/style.css",
    "./ui-provider": {
      "types": "./dist/lib/ui-provider/index.d.ts",
      "import": "./dist/lib/ui-provider/index.js",
      "require": "./dist/lib/ui-provider/index.cjs"
    },
    "./base": {
      "types": "./dist/components/base/index.d.ts",
      "import": "./dist/components/base/index.js",
      "require": "./dist/components/base/index.cjs"
    },
    "./base/*": {
      "types": "./dist/components/base/*/index.d.ts",
      "import": "./dist/components/base/*/index.js",
      "require": "./dist/components/base/*/index.cjs"
    },
    "./composed": {
      "types": "./dist/components/composed/index.d.ts",
      "import": "./dist/components/composed/index.js",
      "require": "./dist/components/composed/index.cjs"
    },
    "./composed/*": {
      "types": "./dist/components/composed/*/index.d.ts",
      "import": "./dist/components/composed/*/index.js",
      "require": "./dist/components/composed/*/index.cjs"
    },
    "./features": {
      "types": "./dist/components/features/index.d.ts",
      "import": "./dist/components/features/index.js",
      "require": "./dist/components/features/index.cjs"
    },
    "./features/*": {
      "types": "./dist/components/features/*/index.d.ts",
      "import": "./dist/components/features/*/index.js",
      "require": "./dist/components/features/*/index.cjs"
    },
    "./layout": {
      "types": "./dist/components/layout/index.d.ts",
      "import": "./dist/components/layout/index.js",
      "require": "./dist/components/layout/index.cjs"
    },
    "./layout/*": {
      "types": "./dist/components/layout/*/index.d.ts",
      "import": "./dist/components/layout/*/index.js",
      "require": "./dist/components/layout/*/index.cjs"
    },
    "./lib/strings": {
      "types": "./dist/lib/strings.d.ts",
      "import": "./dist/lib/strings.js",
      "require": "./dist/lib/strings.cjs"
    },
    "./lib/utils": {
      "types": "./dist/lib/utils.d.ts",
      "import": "./dist/lib/utils.js",
      "require": "./dist/lib/utils.cjs"
    }
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.12"
  },
  "peerDependencies": {
    "@dnd-kit/core": "^6.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.0.0",
    "@fontsource-variable/inter": "^5.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@tanstack/react-table": "^8.0.0",
    "@tiptap/pm": "^3.0.0",
    "@tiptap/react": "^3.0.0",
    "@tiptap/starter-kit": "^3.0.0",
    "cmdk": "^1.0.0",
    "culori": "^4.0.0",
    "leaflet": "^1.0.0",
    "leaflet-draw": "^1.0.0",
    "leaflet.fullscreen": "^5.0.0",
    "leaflet.markercluster": "^1.0.0",
    "lucide-react": "^1.0.0",
    "qrcode": "^1.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-day-picker": "^9.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "react-hook-form": "^7.0.0",
    "react-leaflet": "^5.0.0",
    "react-leaflet-markercluster": "^5.0.0-rc.0",
    "recharts": "^3.0.0",
    "sonner": "^2.0.0",
    "tailwindcss": "^4.0.0",
    "tw-animate-css": "^1.0.0"
  },
